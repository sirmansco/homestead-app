# Database (Neon via Vercel Postgres integration)
DATABASE_URL="postgresql://user:pass@host/db?sslmode=require"
DATABASE_URL_UNPOOLED="postgresql://user:pass@host/db?sslmode=require"
POSTGRES_URL="postgresql://user:pass@host/db?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:pass@host/db?sslmode=require"
POSTGRES_PRISMA_URL="postgresql://user:pass@host/db?connect_timeout=15&sslmode=require"

# Clerk auth
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_..."
CLERK_SECRET_KEY="sk_test_..."

# Vercel Blob (photo uploads)
BLOB_READ_WRITE_TOKEN="vercel_blob_..."

# Web Push (VAPID)
VAPID_SUBJECT="mailto:hello@sirmans.co"
NEXT_PUBLIC_VAPID_PUBLIC_KEY="..."
VAPID_PRIVATE_KEY="..."

# Email (Resend or chosen provider)
RESEND_API_KEY=""
NOTIFY_FROM="Homestead <hello@sirmans.co>"

# App URL (used for absolute links in notifications, iCal exports, etc.)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ───────────────────────────────────────────────────────────────────
# COVEY REBRAND FLAGS (added 2026-04-30)
# Both default to false. Production stays Homestead until both flip true.
# Flag false = byte-identical behavior to pre-rebrand main.
# ───────────────────────────────────────────────────────────────────

# Server-side: gates notification copy, iCal PRODID, email FROM, etc.
# Used in lib/copy.ts selector and any server-side brand decisions.
COVEY_BRAND_ACTIVE="false"

# Client-side: gates PWA manifest, in-app brand strings, app-header logo.
# Must match COVEY_BRAND_ACTIVE in production for consistent UX.
NEXT_PUBLIC_COVEY_BRAND_ACTIVE="false"
